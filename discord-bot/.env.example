# Bot credentials
TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Channel IDs
WELCOME_CHANNEL_ID=channel_id_here
RULES_CHANNEL_ID=channel_id_here

# Role IDs
WELCOME_ROLE_ID=role_id_here        # Role assigned automatically on join
VERIFIED_ROLE_ID=role_id_here       # Role given after accepting rules
MOD_ROLE_ID=role_id_here            # Can use all moderation commands
ADMIN_ROLE_ID=role_id_here          # Can use /rules and /announce + all mod commands

# ─────────────────────────────────────────────────────────────
# TradingView → Discord Webhook (Trading Signals)
# ─────────────────────────────────────────────────────────────

# Discord webhook URL for the trade-signals channel
# Create one via: Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_TRADE_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Port the webhook HTTP server listens on
# Railway auto-injects PORT; set this only for local development
WEBHOOK_PORT=3000

# Optional shared secret — set this string in TradingView alert's
# "Webhook URL" as a query param: ?secret=YOUR_SECRET
# OR send it as the header "x-webhook-secret: YOUR_SECRET"
# Leave blank to disable secret validation (not recommended for production)
WEBHOOK_SECRET=your_strong_random_secret_here
