DISCORD_TOKEN=your_bot_token_here

# Channel where welcome messages are sent
WELCOME_CHANNEL_ID=your_welcome_channel_id_here

# Role assigned immediately on join (should only see #rules)
JOIN_ROLE_ID=your_join_role_id_here

# Role assigned after accepting the rules (unlocks all channels)
VERIFIED_ROLE_ID=your_verified_role_id_here

# Channel where mod actions are logged
MOD_LOG_CHANNEL_ID=your_mod_log_channel_id_here
